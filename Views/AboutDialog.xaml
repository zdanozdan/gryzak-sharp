<Window x:Class="Gryzak.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="O aplikacji"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/gryzak_icon.png">
    
    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek z logo -->
        <Border Grid.Row="0" Background="#2196F3" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" 
                       Source="pack://application:,,,/gryzak.png" 
                       Width="80" 
                       Height="80" 
                       Margin="0,0,20,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Gryzak" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Wersja 1.6.7" 
                               FontSize="16" 
                               Foreground="#E3F2FD"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Zawartość -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Nagłówek sekcji -->
                <TextBlock Text="🛒 Gryzak - Menedżer Zamówień" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2196F3"
                           Margin="0,0,0,20"/>

                <!-- Opis aplikacji -->
                <TextBlock Text="📋 Opis aplikacji" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,10,0,5"/>
                <TextBlock Text="Aplikacja desktopowa do zarządzania zamówieniami ze sklepu internetowego. Umożliwia wyświetlanie, filtrowanie i zarządzanie zamówieniami przy pomocy interfejsu API."
                           TextAlignment="Justify"/>

                <!-- Funkcjonalności -->
                <TextBlock Text="✨ Funkcjonalności" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,20,0,5"/>
                <StackPanel Margin="10,5,0,5">
                    <TextBlock Text="• 📊 Wyświetlanie listy zamówień"/>
                    <TextBlock Text="• 🔍 Filtrowanie zamówień"/>
                    <TextBlock Text="• 📈 Statystyki zamówień"/>
                    <TextBlock Text="• 👁️ Szczegółowy widok zamówienia"/>
                    <TextBlock Text="• 🔄 Automatyczne odświeżanie danych"/>
                    <TextBlock Text="• ⚙️ Konfiguracja API"/>
                    <TextBlock Text="• 📱 Responsywny design"/>
                    <TextBlock Text="• 🎨 Nowoczesny interfejs z ikonami"/>
                </StackPanel>

                <!-- Technologie -->
                <TextBlock Text="🛠️ Technologie" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,20,0,5"/>
                <StackPanel Margin="10,5,0,5">
                    <TextBlock Text="• C# (.NET 8.0)"/>
                    <TextBlock Text="• WPF (Windows Presentation Foundation)"/>
                    <TextBlock Text="• System.Text.Json"/>
                </StackPanel>

                <!-- O Gryzak -->
                <TextBlock Text="👨‍💻 O Gryzak" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,20,0,5"/>
                <TextBlock Text="Gryzak to profesjonalne narzędzie do zarządzania zamówieniami, stworzone z myślą o wygodzie i efektywności pracy."
                           TextAlignment="Justify"/>

                <!-- Kontakt -->
                <TextBlock Text="📞 Kontakt" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,20,0,5"/>
                <TextBlock Text="Więcej informacji o aplikacji można znaleźć w dokumentacji projektu."
                           TextAlignment="Justify"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Stopka -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="© 2024 Gryzak. Wszystkie prawa zastrzeżone." 
                           FontSize="11" 
                           Foreground="#666"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                        Content="Zamknij" 
                        IsDefault="True" 
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

